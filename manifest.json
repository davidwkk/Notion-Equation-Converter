{
  "name": "Notion Equation Converter",
  "description": "Convert LaTeX equations to native Notion math blocks. Supports \\[ \\], $$, \\( \\), $ delimiters, auto-convert & keyboard shortcut.",
  "version": "2.0.0",
  "manifest_version": 3,
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*.notion.so/*",
        "*://*.notion.site/*",
        "*://*.notion.com/*",
        "*://notion.so/*",
        "*://notion.site/*",
        "*://notion.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Convert Notion Equations",
    "default_icon": "icon.png"
  },
  "author": "David Wong",
  "homepage_url": "https://github.com/davidwkk/notion-equation-converter"
}
